{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedOrigins": [],
  "ReverseProxy": {
    "Routes": {
      "ingest-route": {
        "ClusterId": "ingestion_cluster",
        "Match": {
          "Path": "/api/v1/ingest/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/v1/ingest/{**catch-all}" },
          { "RequestHeader": "X-Forwarded-By", "Set": "yarp-gateway" }
        ]
      },
      "analysis-route": {
        "ClusterId": "analysis_cluster",
        "Match": {
          "Path": "/api/v1/analysis/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/v1/analysis/{**catch-all}" },
          { "RequestHeader": "X-Forwarded-By", "Set": "yarp-gateway" }
        ]
      },
      "health-route": {
        "ClusterId": "ingestion_cluster",
        "Match": {
          "Path": "/actuator/health"
        }
      }
    },
    "Clusters": {
      "ingestion_cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Passive": {
            "Enabled": true,
            "ReactivationPeriod": "00:00:30"
          },
          "Active": {
            "Enabled": true,
            "Interval": "00:00:15",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/actuator/health"
          }
        },
        "Destinations": {
          "primary": {
            "Address": "http://ingestion-service:8081/"
          }
        }
      },
      "analysis_cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Passive": { "Enabled": true, "ReactivationPeriod": "00:00:30" },
          "Active": {
            "Enabled": true,
            "Interval": "00:00:15",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "primary": {
            "Address": "http://analysis-service:8082/"
          }
        }
      }
    }
  }
}
